# Configuración del servidor
PORT=3000               # Puerto donde corre la API
NODE_ENV=development    # environment: development | production | test
LOG_LEVEL=debug         # nivel de logs: error,warn,log,debug,verbose

# Configuración de la base de datos PostgreSQL
DB_HOST=localhost       # host de la base de datos
DB_PORT=5432            # puerto de PostgreSQL
POSTGRES_USER=postgres  # usuario de DB
POSTGRES_PASSWORD=password  # contraseña de DB
POSTGRES_DB=splitease   # nombre de la base de datos

# JWT
JWT_SECRET=change_this_a_strong_secret  # clave secreta JWT, obligatorio
